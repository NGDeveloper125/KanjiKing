<Page x:Class="KanjiKingInterface.Pages.EndGame.EndGameView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="EndGameView">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="270"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Kanji King" FontSize="40" FontFamily="Cambria" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,0" />
            <TextBlock Grid.Row="1" Text="{Binding UserKanjiResult}" FontFamily="Cambria" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="27" TextWrapping="Wrap" Margin="10,0,0,120"/>
        <Button Grid.Row="2" Content="Play Again" Command="{Binding PlayAgainCommand}" Width="120" FontSize="20" Padding="10,5" Margin="0,0,200,0"/>
            <Button Grid.Row="2" Content="MainMenu" Command="{Binding GoToMainMenuCommand}" Width="120" FontSize="20" Padding="10,5" Margin="200,0,0,0"/>
    </Grid>
</Page>